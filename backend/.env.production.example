PORT = '4000'
NODE_ENV = 'production'
FRONTEND_URL = 'https://your-frontend-url.vercel.app'
MONGO_URI = 'mongodb+srv://username:password@cluster.mongodb.net/doctor-appointment?retryWrites=true&w=majority'

JWT_SECRET = "your_strong_jwt_secret_min_32_characters_long"
JWT_EXPIRE = "3d"
REFRESH_TOKEN_SECRET = "your_strong_refresh_token_secret_min_32_characters"
REFRESH_TOKEN_EXPIRE = "7d"
COOKIE_EXPIRE= "5"

SMPT_SERVICE = "gmail"
SMPT_HOST = "smtp.gmail.com"
SMPT_PORT = "465" 
SMPT_MAIL = 'your_email@gmail.com'
SMPT_PASSWORD = 'your_gmail_app_password'

# Rate Limiting
RATE_LIMIT_WINDOW_MS = '900000'
RATE_LIMIT_MAX_REQUESTS = '100'

# Account Lockout
MAX_LOGIN_ATTEMPTS = '5'
LOCKOUT_TIME_MS = '900000'

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME = 'your_cloudinary_cloud_name'
CLOUDINARY_API_KEY = 'your_cloudinary_api_key'
CLOUDINARY_API_SECRET = 'your_cloudinary_api_secret'

# Zoom Configuration
ZOOM_API_KEY = 'your_zoom_api_key'
ZOOM_API_SECRET = 'your_zoom_api_secret'

# Redis Configuration
REDIS_HOST = 'your-redis-cloud-host'
REDIS_PORT = '6379'
REDIS_PASSWORD = 'your_redis_password'
REDIS_DB = '0'

# Timezone for schedulers
TIMEZONE = 'UTC'
